{
  "name": "nanodrop.io",
  "version": "2.0.0",
  "description": "Free Nano cryptocurrency (XNO) Faucet",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "next build",
    "dev": "concurrently --kill-others-on-fail --names web,api \"npm:dev:ui\" \"npm:dev:api\"",
    "dev:ui": "next dev",
    "dev:api": "npm run db:local:migrate && wrangler dev --config wrangler.faucet-dev.jsonc --port 8787",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --config .prettierrc.json --write .",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "db:local:migrate": "wrangler d1 migrations apply NANODROP_DB --local --config wrangler.faucet-dev.jsonc",
    "db:staging:migrate": "wrangler d1 migrations apply NANODROP_DB --remote --env staging --config wrangler.jsonc",
    "db:production:migrate": "wrangler d1 migrations apply NANODROP_DB --remote --config wrangler.jsonc",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@hcaptcha/react-hcaptcha": "^1.12.1",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@mui/material": "^5.14.8",
    "@opennextjs/cloudflare": "^1.19.3",
    "@sentry/nextjs": "^9.47.1",
    "bignumber.js": "^11.0.0",
    "clsx": "^2.0.0",
    "hono": "^4.12.15",
    "jsqr": "^1.4.0",
    "nano-wallet-js": "^0.2.1",
    "nanocurrency": "^2.5.0",
    "next": "^15.5.15",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^9.0.0",
    "react-qr-code": "^2.0.12",
    "react-svg-worldmap": "2.0.0-alpha.16",
    "react-timeago": "^7.2.0",
    "remark-gfm": "^4.0.0",
    "swr": "^2.2.2",
    "tailwind-scrollbar": "^3.0.5",
    "use-sound": "^4.0.1",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18.2.7",
    "@types/react-timeago": "^4.1.3",
    "autoprefixer": "^10.4.15",
    "eslint": "^8.48.0",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "postcss": "^8.4.29",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.3.3",
    "tailwindcss-safe-area": "^0.4.0",
    "typescript": "^5.2.2",
    "wrangler": "^4.84.1"
  }
}
